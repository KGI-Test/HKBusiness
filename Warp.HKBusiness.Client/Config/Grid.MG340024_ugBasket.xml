<UltraGrid>
	<DisplayLayout
		ColumnChooserButton = "False"
	/>
	<DataSet>
		<DataTable>
			<Columns ColumnName = "HKAVL_DATE" Caption="Date" Width="80" Format="####/##/##"/>
			<Columns ColumnName = "INSALA_CODE" Caption="Ticker" Width="100"/>
			<Columns ColumnName = "USD_TOTAL_SIZE" Caption="USD Total Size"  Style ="Double" Format="#,##0.##" MaskInput = "nnn,nnn.nn" Width="80" />
			<Columns ColumnName = "USD_SBL_LENT" Caption="USD SBL Lent"  Style ="Double" Format="#,##0.##" MaskInput = "nnn,nnn.nn" Width="80" />
